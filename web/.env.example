# WalletConnect Cloud project id — get one at https://cloud.reown.com (formerly cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=

# The Graph gateway API key — https://thegraph.com/studio/apikeys/
NEXT_PUBLIC_GRAPH_API_KEY=

# Deployed USDC-on-Arbitrum subgraph URL (your custom subgraph)
# Example (decentralized network): https://gateway.thegraph.com/api/<API_KEY>/subgraphs/id/<SUBGRAPH_ID>
NEXT_PUBLIC_USDC_SUBGRAPH_URL=

# Aave V3 Arbitrum subgraph URL. The Markets Overview component is tuned to
# your custom subgraph's schema (Reserve + DailyReserveStat with liquidityRate,
# variableBorrowRate, totalSupply, totalBorrow, dailyStats). USD prices come
# from Chainlink feeds on-chain — no `priceUSD` field is required in the
# subgraph itself.
# Example:
# NEXT_PUBLIC_AAVE_SUBGRAPH_URL=https://gateway.thegraph.com/api/<API_KEY>/subgraphs/id/<YOUR_AAVE_SUBGRAPH_ID>
NEXT_PUBLIC_AAVE_SUBGRAPH_URL=

# Arbitrum JSON-RPC URL used by viem for contract reads (public endpoint is fine for light usage)
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Server-only — Anthropic API key for the Sentinel chat agent
ANTHROPIC_API_KEY=

# ----- x402 agentic payments -----
# Public site URL — used by the agent + paywalled endpoint to build absolute
# resource URLs. In dev: http://localhost:3000. In prod: your Vercel URL.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Address that receives x402 payments to /api/agent/premium-analysis.
# Use a wallet you control on Arbitrum One (and Base, if you accept Base).
X402_RECEIVER_ADDRESS=

# 0x-prefixed private key of the facilitator wallet. Pays gas to submit
# signed authorizations on-chain. Needs a small ETH balance on Arbitrum
# (and Base if used). Use a fresh, dedicated key. DO NOT commit.
FACILITATOR_PRIVATE_KEY=

# 0x-prefixed private key of the agent's wallet. Used by the
# get_premium_analysis tool to sign EIP-3009 authorizations. Needs USDC
# (no ETH gas — facilitator pays). DO NOT commit.
AGENT_PRIVATE_KEY=

# Optional: dedicated RPCs. Fall back to public RPCs.
ARBITRUM_RPC_URL=
BASE_RPC_URL=
