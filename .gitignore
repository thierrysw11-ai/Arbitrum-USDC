# --- Dependencies (anywhere in the tree) ---
node_modules/
**/node_modules/

# --- Build artifacts ---
# Subgraph generated/build (regenerated by `graph codegen` / `graph build`)
**/build/
**/generated/
# Next.js
.next/
**/.next/
out/
**/out/

# --- Pre-reorg leftovers at the repo root only ---
# Kept ignored so they can't accidentally come back if anyone re-adds them.
/abis/
/src/
/package.json
/package-lock.json
/hardhat.config.js
/subgraph.yaml
/schema.graphql

# --- Env files (never commit secrets) ---
.env
.env.local
.env.*.local
.env*.local
**/.env.local
!.env.example
!**/.env.example

# --- IDE / OS ---
.DS_Store
.vscode/
.idea/
*.swp
Thumbs.db

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Hardhat (legacy) ---
cache/
artifacts/
typechain-types/
coverage/
coverage.json

# --- Misc ---
.DS_Store
.turbo/
